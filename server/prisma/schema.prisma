generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Juego {
  FC25
  COD_BO2
}

model Inscripcion {
  id                   String   @id @default(uuid())
  nombreCompleto       String
  nickname             String?
  nicknameNormalizado  String?
  documento            String?
  juego                Juego
  createdAt            DateTime @default(now())

  // COD BO2 team fields
  jugador1Nombre       String?
  jugador2Nombre       String?
  ficha                String?
  programa             String?
  correo               String?
  telefono             String?
  nickEquipo           String?

  @@unique([juego, nicknameNormalizado])
  @@unique([juego, documento])
}

model EstadoInscripciones {
  juego     Juego    @id
  abierta   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

enum FormatoBracket {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
}

enum LadoBracket {
  WINNERS
  LOSERS
}

model Bracket {
  id        String         @id @default(uuid())
  juego     Juego          @unique
  formato   FormatoBracket
  createdAt DateTime       @default(now())
  partidos  Partido[]
}

model Partido {
  id               String       @id @default(uuid())
  bracketId        String
  bracket          Bracket      @relation(fields: [bracketId], references: [id])
  ronda            Int
  lado             LadoBracket?
  jugadorAId       String?
  jugadorBId       String?
  scoreA           Int?
  scoreB           Int?
  penaltyScoreA    Int?
  penaltyScoreB    Int?
  winnerId         String?
  nextMatchId      String?
  nextLoserMatchId String?
  resolvedAt       DateTime?
}

// ─── Fase de grupos ───────────────────────────────────────────────────────────

enum EstadoFaseGrupos {
  PENDIENTE   // grupos creados, sin resultados
  EN_CURSO    // al menos un partido jugado
  FINALIZADA  // todos los partidos jugados, clasificados determinados
}

model FaseGrupos {
  id        String           @id @default(uuid())
  juego     Juego            @unique
  estado    EstadoFaseGrupos @default(PENDIENTE)
  createdAt DateTime         @default(now())
  grupos    Grupo[]
}

model Grupo {
  id             String          @id @default(uuid())
  faseId         String
  fase           FaseGrupos      @relation(fields: [faseId], references: [id])
  nombre         String          // "Grupo A", "Grupo B", …
  participantes  GrupoParticipante[]
  partidos       PartidoGrupo[]
}

// Las estadísticas (puntos, PJ-PG-PE-PP, goles) no se almacenan:
// se calculan siempre desde los resultados de PartidoGrupo al leer.
model GrupoParticipante {
  id             String  @id @default(uuid())
  grupoId        String
  grupo          Grupo   @relation(fields: [grupoId], references: [id])
  inscripcionId  String  // referencia lógica a Inscripcion.id
  clasificado    Boolean @default(false)
}

model PartidoGrupo {
  id          String    @id @default(uuid())
  grupoId     String
  grupo       Grupo     @relation(fields: [grupoId], references: [id])
  ronda       Int?      // ronda del round-robin (metodo circular); null en partidos generados antes de este campo
  jugadorAId  String    // inscripcionId
  jugadorBId  String
  scoreA      Int?
  scoreB      Int?
  winnerId    String?   // null si empataron
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
}
